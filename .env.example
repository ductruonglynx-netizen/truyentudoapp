# Supabase auth + workspace storage.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_WORKSPACES_TABLE="user_workspaces"
VITE_SUPABASE_QA_REPORTS_TABLE="qa_reports"
VITE_SUPABASE_STORIES_TABLE="stories"
VITE_SUPABASE_CHAPTERS_TABLE="story_chapters"
VITE_SUPABASE_CHARACTERS_TABLE="workspace_characters"
VITE_SUPABASE_AI_RULES_TABLE="workspace_ai_rules"
VITE_SUPABASE_TRANSLATION_NAMES_TABLE="workspace_translation_names"
VITE_SUPABASE_STYLE_REFERENCES_TABLE="workspace_style_references"
VITE_SUPABASE_CLIENT_ERRORS_TABLE="client_error_events"
VITE_SUPABASE_API_TELEMETRY_TABLE="api_key_telemetry_events"
# 1 = bật autosync tài khoản Supabase, 0 = tắt.
VITE_ACCOUNT_AUTOSYNC="1"
VITE_ENABLE_ERROR_MONITORING="1"
VITE_ENABLE_API_TELEMETRY="1"
VITE_ENABLE_WEBGPU="0"
VITE_WEBGPU_STABILITY_ITERATIONS="90"

# Maintenance mode controls.
# Bật 1 trong các biến dưới = "1" để khóa khu tương ứng.
# - VITE_MAINTENANCE_MODE / VITE_MAINTENANCE_MODE_GLOBAL: khóa toàn bộ web
# - VITE_MAINTENANCE_MODE_READER: chỉ khóa khu đọc
# - VITE_MAINTENANCE_MODE_STUDIO: chỉ khóa Studio
VITE_MAINTENANCE_MODE="0"
VITE_MAINTENANCE_MODE_GLOBAL="0"
VITE_MAINTENANCE_MODE_READER="0"
VITE_MAINTENANCE_MODE_STUDIO="0"
# Nội dung hiển thị trang bảo trì (tùy chọn)
VITE_MAINTENANCE_NOTICE="Hệ thống đang bảo trì để nâng cấp và sửa lỗi."
VITE_MAINTENANCE_NOTICE_GLOBAL=""
VITE_MAINTENANCE_NOTICE_READER=""
VITE_MAINTENANCE_NOTICE_STUDIO=""
# Thời gian dự kiến mở lại (tùy chọn).
# Có thể dùng ISO: 2026-03-31T02:30:00+08:00
# hoặc dạng: 31/03/2026 02:30 GMT+8
# Khi tới ETA, app sẽ tự bỏ chế độ bảo trì ở client.
# Thời gian bắt đầu bảo trì sẽ được app tự ghi nhận khi chế độ bảo trì được mở.
VITE_MAINTENANCE_ETA=""

# Optional provider keys for local development.
# Set optional API keys in `.env.local` (local only) or Vercel Environment Variables.
# Supported variable names:
# - VITE_GEMINI_API_KEY
# - VITE_OPENAI_API_KEY
# - VITE_ANTHROPIC_API_KEY
# - VITE_RAPHAEL_API_KEY
VITE_RAPHAEL_MODEL="z-image-turbo"
VITE_RAPHAEL_SIZE="2:3"
VITE_GOOGLE_DRIVE_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"

# WebSocket relay backend.
# Query style: wss://your-relay.workers.dev/?code=1234
# Path style:  wss://your-relay.workers.dev/1234
VITE_RELAY_WS_BASE="wss://your-relay.workers.dev/"

# Relay web/publish base used in UI hints.
VITE_RELAY_WEB_BASE="https://your-relay.workers.dev/"

# Credentials for import scripts in `scripts/`
IMPORT_EMAIL="your-email@example.com"
IMPORT_PASSWORD="your-password"
